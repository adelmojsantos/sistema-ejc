{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "ejc-fotos",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-06",
  "workers_dev": true,
  "keep_vars": true,
  "vars": {
    "ALLOWED_ORIGINS": "https://ejc-capelinha.vercel.app,http://localhost:5173,http://127.0.0.1:5173"
  },
  "r2_buckets": [
    {
      "binding": "FOTOS_BUCKET",
      "bucket_name": "ejc-fotos-producao"
    }
  ]
}
